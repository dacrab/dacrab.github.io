---
import { projects } from '../data/projects';
---

<section id="projects" class="relative border-t border-white/10 bg-zinc-950 px-6 py-32 text-white md:px-12">
  <div class="mx-auto max-w-7xl">
    <div class="projects-header mb-24 flex items-end justify-between border-b border-white/10 pb-8">
      <h2 class="text-6xl font-bold tracking-tighter text-white md:text-8xl">
        SELECTED<br />WORKS
      </h2>
      <span class="mb-2 hidden font-mono text-sm text-zinc-400 md:block">
        (2023 — {new Date().getFullYear()})
      </span>
    </div>

    <div class="projects-list">
      {projects.map((project, index) => (
        <a
          href={project.link}
          target="_blank"
          rel="noopener noreferrer"
          class="project-row group block border-b border-white/5 py-6 md:py-8"
          data-index={index}
        >
          <!-- Main row -->
          <div class="flex items-center justify-between gap-4">
            <div class="flex items-baseline gap-4 md:gap-8 overflow-hidden">
              <span class="font-mono text-sm text-zinc-600 transition-colors duration-300 group-hover:text-zinc-400">
                {String(index + 1).padStart(2, '0')}
              </span>
              <h3 class="project-title text-2xl font-bold tracking-tight transition-all duration-500 group-hover:tracking-normal md:text-5xl lg:text-6xl">
                {project.title}
              </h3>
            </div>

            <div class="flex items-center gap-4 shrink-0">
              <span class="hidden text-sm text-zinc-600 transition-colors duration-300 group-hover:text-zinc-400 md:block">
                {project.tech[0]}
              </span>
              <div class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 transition-all duration-300 group-hover:border-white/30 group-hover:bg-white/5">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 10 10"
                  fill="none"
                  aria-hidden="true"
                  class="text-zinc-500 transition-all duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-white"
                >
                  <path d="M1 9L9 1M9 1H3M9 1V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Expandable detail (hidden by default, shown on hover via GSAP) -->
          <div class="project-detail grid grid-cols-1 gap-4 overflow-hidden md:grid-cols-2" style="height: 0; opacity: 0;">
            <p class="pt-4 text-base leading-relaxed text-zinc-400">
              {project.blurb}
            </p>
            <div class="flex flex-wrap items-start justify-end gap-2 pt-4">
              {project.tech.map((t) => (
                <span class="rounded-full border border-white/10 px-3 py-1 text-xs tracking-widest text-zinc-500 uppercase">
                  {t}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const isMobile = window.matchMedia('(hover: none)').matches;

  // Header reveal
  gsap.set('.projects-header', { opacity: 0, clipPath: 'inset(0 100% 0 0)' });
  gsap.to('.projects-header', {
    opacity: 1, clipPath: 'inset(0 0% 0 0)', duration: 1.2, ease: 'power4.inOut',
    scrollTrigger: { trigger: '.projects-header', start: 'top 80%', once: true },
  });

  // Row reveals
  for (const row of document.querySelectorAll('.project-row')) {
    gsap.fromTo(row,
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out',
        scrollTrigger: { trigger: row, start: 'top 90%', once: true } },
    );
  }

  // Hover expand (desktop only)
  if (!isMobile) {
    for (const row of document.querySelectorAll<HTMLElement>('.project-row')) {
      const detail = row.querySelector<HTMLElement>('.project-detail');
      if (!detail) continue;

      row.addEventListener('mouseenter', () => {
        gsap.killTweensOf(detail);
        gsap.to(detail, { height: 'auto', opacity: 1, duration: 0.4, ease: 'power3.out' });
      });
      row.addEventListener('mouseleave', () => {
        gsap.killTweensOf(detail);
        gsap.to(detail, { height: 0, opacity: 0, duration: 0.3, ease: 'power3.in' });
      });
    }
  } else {
    // On mobile, show details always
    for (const detail of document.querySelectorAll<HTMLElement>('.project-detail')) {
      detail.style.height = 'auto';
      detail.style.opacity = '1';
    }
  }
</script>
