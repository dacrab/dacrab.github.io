<section
  class="relative flex min-h-screen flex-col justify-center overflow-hidden px-6 pt-32 md:px-12"
  id="hero-section"
>
  <div class="relative z-10 mx-auto w-full max-w-[90vw]">
    <h1 class="hero-title text-[12vw] leading-[0.85] font-bold tracking-tighter text-zinc-900">
      <span class="block overflow-hidden">
      <span class="word inline-block">VAGGELIS</span>
      </span>
      <span class="block overflow-hidden">
        <span class="word crab-trigger inline-block">KAVOURAS</span>
      </span>
    </h1>

    <div class="mt-12 ml-auto flex max-w-4xl flex-col items-start gap-8 md:flex-row md:gap-24">
      <div class="overflow-hidden">
        <p class="hero-text max-w-md text-xl leading-relaxed text-zinc-600 md:text-2xl">
          Full-Stack Web Developer specialized in building high-performance applications with
          Next.js, Astro, and SvelteKit.
        </p>
      </div>

      <a
        href="#projects"
        class="hero-actions hero-btn relative inline-flex h-12 items-center justify-center overflow-hidden rounded-full bg-zinc-900 px-6 font-medium text-white"
      >
        <span>View Projects</span>
        <span class="hero-btn-arrow ml-0 w-0 overflow-hidden">
          <svg class="ml-2" width="16" height="16" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M1 9L9 1M9 1H1M9 1V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const isMobile = window.matchMedia('(hover: none)').matches;

  gsap.set('.hero-title .word', { y: '100%', autoAlpha: 0 });
  gsap.set(['.hero-text', '.hero-actions'], { autoAlpha: 0, y: 32 });

  if (isMobile) {
    gsap.timeline({ delay: 0.1 })
      .to('.hero-title .word', { y: 0, autoAlpha: 1, duration: 0.5 })
      .to(['.hero-text', '.hero-actions'], { autoAlpha: 1, y: 0, duration: 0.4 }, '-=0.2');
  } else {
    gsap.timeline({ defaults: { ease: 'expo.out' }, delay: 0.3 })
      .to('.hero-title .word', { y: 0, autoAlpha: 1, duration: 1.5, stagger: 0.1, ease: 'power4.out' })
      .to('.hero-text', { autoAlpha: 1, y: 0, duration: 1.2 }, '-=1.0')
      .to('.hero-actions', { autoAlpha: 1, y: 0, duration: 1.2 }, '-=1.0');

    gsap.to('.hero-title', {
      y: 80,
      ease: 'none',
      scrollTrigger: { trigger: '#hero-section', start: 'top top', end: 'bottom top', scrub: 1.5 },
    });

    const btn = document.querySelector('.hero-btn');
    const arrow = btn?.querySelector('.hero-btn-arrow');
    if (btn && arrow) {
      btn.addEventListener('mouseenter', () => {
        gsap.to(btn, { backgroundColor: '#27272a', duration: 0.3 });
        gsap.to(arrow, { width: 24, duration: 0.5, ease: 'power3.out' });
      });
      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, { backgroundColor: '#18181b', duration: 0.3 });
        gsap.to(arrow, { width: 0, duration: 0.5, ease: 'power3.out' });
      });
    }
  }
</script>
