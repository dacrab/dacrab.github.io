---
const year = new Date().getFullYear();

const socials = [
  { label: 'GITHUB', href: 'https://github.com/dacrab' },
  { label: 'LINKEDIN', href: 'https://linkedin.com/in/vkavouras' },
  { label: 'EMAIL', href: 'mailto:vkavouras@proton.me' },
] as const;
---

<footer class="footer-section overflow-hidden border-t border-white/10 bg-zinc-950 px-6 pt-20 pb-8 md:px-12">
  <div class="mx-auto max-w-[90vw]">
    <!-- Giant ghost text with stroke effect -->
    <p class="footer-name crab-trigger pointer-events-auto mb-12 text-center text-[16vw] leading-none font-black tracking-tighter text-transparent select-none [-webkit-text-stroke:2px_rgba(255,255,255,0.12)] md:text-left">
      KAVOURAS
    </p>

    <!-- Bottom bar -->
    <div class="flex flex-col items-center justify-between gap-6 border-t border-white/5 pt-8 md:flex-row">
      <div class="flex gap-6 font-mono text-sm text-zinc-600">
        {socials.map(({ label, href }) => (
          <a
            href={href}
            target={href.startsWith('mailto') ? undefined : '_blank'}
            rel={href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            class="magnetic transition-colors hover:text-white"
          >{label}</a>
        ))}
      </div>

      <p class="text-xs tracking-widest text-zinc-600 uppercase">
        &copy; {year} Vaggelis Kavouras
      </p>
    </div>
  </div>
</footer>

<script>
  import gsap from 'gsap';

  gsap.set('.footer-name', { opacity: 0, y: 60 });

  gsap.to('.footer-name', {
    opacity: 1, y: 0, duration: 1.2, ease: 'power3.out',
    scrollTrigger: { trigger: '.footer-section', start: 'top 85%', once: true },
  });
</script>
