<section id="about" class="border-t border-white/10 bg-zinc-900 px-6 py-32 text-zinc-50 md:px-12">
  <div class="mx-auto max-w-5xl">
    <h2 class="about-heading mb-20 text-4xl leading-tight font-bold tracking-tight md:text-6xl">
      Engineering-first developer obsessed with <span class="text-zinc-500">performance</span>,
      <span class="text-zinc-500">motion</span>, and <span class="text-zinc-500">zero bloat</span>.
    </h2>

    <div class="grid grid-cols-1 gap-16 md:grid-cols-5">
      <div class="about-text space-y-6 text-lg leading-relaxed text-zinc-400 md:col-span-3">
        <p>
          I build marketing sites and full-stack apps that consistently hit 95+ Lighthouse scores
          while delivering rich, interactive experiences. Every line of code earns its place.
        </p>
        <p>
          From multilingual UIs and scroll-driven animations to real-time backends and SaaS
          platforms — I handle the full stack with the same attention to craft throughout.
        </p>
      </div>

      <div class="space-y-10 md:col-span-2">
        <div>
          <h3 class="mb-4 text-xs font-bold tracking-widest text-zinc-500 uppercase">Stack</h3>
          <div class="about-stack flex flex-wrap gap-2">
            {['TypeScript', 'Next.js', 'React', 'SvelteKit', 'Astro', 'Tailwind CSS', 'GSAP', 'Supabase', 'PostgreSQL', 'Convex'].map((item) => (
              <span class="stack-item rounded-full border border-white/10 px-3 py-1.5 text-sm text-zinc-400 transition-colors hover:border-white/25 hover:text-white">
                {item}
              </span>
            ))}
          </div>
        </div>

        <div id="contact" class="about-contact">
          <h3 class="mb-4 text-xs font-bold tracking-widest text-zinc-500 uppercase">Let's work together</h3>
          <a
            href="mailto:vkavouras@proton.me"
            class="magnetic inline-block text-xl font-bold text-white transition-colors hover:text-zinc-400"
          >
            vkavouras@proton.me
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  gsap.set('.about-heading', { opacity: 0, y: 40 });
  gsap.set('.about-text', { opacity: 0, y: 30 });
  gsap.set('.stack-item', { opacity: 0, scale: 0.8 });
  gsap.set('.about-contact', { opacity: 0, y: 20 });

  gsap.timeline({
    scrollTrigger: { trigger: '#about', start: 'top 70%', once: true },
  })
    .to('.about-heading', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' })
    .to('.about-text', { opacity: 1, y: 0, duration: 0.8 }, '-=0.5')
    .to('.stack-item', { opacity: 1, scale: 1, duration: 0.4, stagger: 0.05 }, '-=0.4')
    .to('.about-contact', { opacity: 1, y: 0, duration: 0.6 }, '-=0.2');
</script>
